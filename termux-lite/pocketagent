#!/data/data/com.termux/files/usr/bin/bash
set -eu

POCKETAGENT_HOME="${POCKETAGENT_HOME:-$HOME/.pocketagent}"
APP_DIR="$POCKETAGENT_HOME/app"
PID_FILE="$POCKETAGENT_HOME/gateway.pid"
LOG_FILE="$POCKETAGENT_HOME/logs/gateway.log"
PYTHON_BIN="${PYTHON_BIN:-python}"

if [ ! -f "$APP_DIR/pocketagent.py" ]; then
  echo "PocketAgent 程序不存在，请重新运行 install.sh。" >&2
  exit 1
fi

mkdir -p "$POCKETAGENT_HOME/logs"

is_running() {
  [ -f "$PID_FILE" ] || return 1
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

command="${1:-help}"
case "$command" in
  start)
    if is_running; then
      echo "PocketAgent 已在运行，PID $(cat "$PID_FILE")"
      exit 0
    fi
    nohup "$PYTHON_BIN" "$APP_DIR/pocketagent.py" serve >>"$LOG_FILE" 2>&1 &
    echo "$!" > "$PID_FILE"
    sleep 1
    if is_running; then
      echo "PocketAgent 已启动：http://127.0.0.1:8765"
    else
      echo "启动失败，请运行 pocketagent logs 查看原因。" >&2
      exit 1
    fi
    ;;
  stop)
    if is_running; then
      pid="$(cat "$PID_FILE")"
      kill "$pid"
      rm -f "$PID_FILE"
      echo "PocketAgent 已停止。"
    else
      rm -f "$PID_FILE"
      echo "PocketAgent 当前未运行。"
    fi
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
  status)
    if is_running; then
      echo "PocketAgent 正在运行，PID $(cat "$PID_FILE")"
      echo "Web UI：http://127.0.0.1:8765"
    else
      echo "PocketAgent 未运行。"
      exit 1
    fi
    ;;
  logs)
    if [ -f "$LOG_FILE" ]; then
      tail -n 120 "$LOG_FILE"
    else
      echo "暂无日志。"
    fi
    ;;
  update)
    if [ -f "$POCKETAGENT_HOME/source/install.sh" ]; then
      bash "$POCKETAGENT_HOME/source/install.sh" --update --no-config
    else
      echo "当前是本地原型安装。请把新版源码传到平板后重新运行 bash install.sh。"
      echo "正式发布后，update 将使用带 SHA256 校验的发布包。"
    fi
    ;;
  uninstall)
    "$0" stop >/dev/null 2>&1 || true
    purge="${2:-}"
    case "$POCKETAGENT_HOME" in
      ""|"/"|"$HOME")
        echo "拒绝使用不安全的 POCKETAGENT_HOME：$POCKETAGENT_HOME" >&2
        exit 1
        ;;
    esac
    rm -rf "$APP_DIR"
    rm -f "$PID_FILE"
    rm -f "${PREFIX:-/data/data/com.termux/files/usr}/bin/pocketagent"
    if [ "$purge" = "--purge" ]; then
      printf '这会删除配置、密钥、会话和日志。输入 DELETE-POCKETAGENT 确认：'
      read -r confirmation
      if [ "$confirmation" = "DELETE-POCKETAGENT" ]; then
        rm -rf "$POCKETAGENT_HOME"
        echo "PocketAgent 程序数据已完全清除。工作目录未删除。"
      else
        echo "未确认完全清除；配置和用户数据已保留在 $POCKETAGENT_HOME。"
      fi
    else
      echo "程序已卸载；配置、密钥、会话和工作目录已保留。"
      echo "完全清除程序数据可使用：pocketagent uninstall --purge"
    fi
    ;;
  configure|chat|serve|doctor|report|version)
    shift
    exec "$PYTHON_BIN" "$APP_DIR/pocketagent.py" "$command" "$@"
    ;;
  help|-h|--help)
    cat <<'EOF'
PocketAgent 命令：
  pocketagent configure          配置国内模型 API 和工具权限
  pocketagent doctor             检查环境与网络
  pocketagent doctor --test-api  实际测试一次模型调用
  pocketagent report             生成不调用模型的脱敏实机报告
  pocketagent report --test-api  报告中加入一次真实模型测试
  pocketagent chat               在 Termux 中对话
  pocketagent start              后台启动本地 Web UI
  pocketagent stop               停止 Web UI
  pocketagent restart            重启 Web UI
  pocketagent status             查看运行状态
  pocketagent logs               查看脱敏后的运行日志
  pocketagent update             更新本地程序
  pocketagent uninstall          卸载程序并保留用户数据
  pocketagent uninstall --purge  二次确认后清除配置、密钥、会话和日志
EOF
    ;;
  *)
    echo "未知命令：$command" >&2
    "$0" help
    exit 2
    ;;
esac
